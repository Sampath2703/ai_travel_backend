# Copy this file to .env and fill in your keys.
# cp .env.example .env

# Required — powers the AI agent
GROQ_API_KEY=your_groq_key_here
# Get free key: https://console.groq.com/keys

# Required — web search for places, food, activities, bus fallback
TAVILY_API_KEY=your_tavily_key_here
# Get free key: https://app.tavily.com/

# Optional — weather tool
OPENWEATHER_API_KEY=your_openweather_key_here
# Get free key: https://home.openweathermap.org/users/sign_up

# --- FLIGHTS (pick one or both) ---

# Best free option for flight search, prices, and schedules
AMADEUS_API_KEY=your_amadeus_client_id
AMADEUS_API_SECRET=your_amadeus_client_secret
# Get free test keys: https://developers.amadeus.com/register
# Free monthly quota in test environment (cached/sample data)

# Optional — live flight status by flight number
AVIATIONSTACK_API_KEY=your_aviationstack_key
# Get free key (100 requests/month): https://aviationstack.com/signup/free

# --- TRAINS (India) ---

# Option A (recommended): leave ERAIL_API_KEY empty — app uses NTES directly (no key)
# Option B: eRail.in API (email approval required)
ERAIL_API_KEY=your_erail_key_here
# Request key: email info@erail.in or register at http://api.erail.in/auth/register

# Option C: Parse RailYatri wrapper (100 free calls/month)
PARSE_API_KEY=your_parse_api_key
# Get free key: https://parse.bot/

# --- BUSES (India — city-specific, no single national free live API) ---

# Delhi live bus GPS (request access from govt portal)
DELHI_OTD_API_KEY=your_delhi_otd_key_here
# Request key: https://opendata.iiitd.edu.in/ or https://otd.delhi.gov.in/

# Note: Bengaluru BMTC live data has no official public API key.
# The app falls back to Tavily web search for bus routes when no city key is set.
